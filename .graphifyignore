# --- Environments & Credentials ---
.env
.env.local
.env.*.local
*.pem
*.key
secrets.json

# --- Graphify Core & Cache ---
.graphify/
.graphify-cache/
*.graphify.lock
graphify.config.local.json

# --- Database & Embedded Stores ---
